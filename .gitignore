.venv/
__pycache__/
*.pyc
data/
*.db
*.db-wal
*.db-shm
*.mfl
*.mfl-wal
*.mfl-shm
# Exception: the fictional public demo file IS versioned (screenshots dataset).
# Its transient -wal/-shm sidecars stay ignored — the generator checkpoints so
# the committed .mfl is self-contained.
!mfl_public.mfl
.env
dist/
build/
# License-signing private key (ADR-079) — must NEVER be committed or bundled.
tools/.dev_signing_key
*.signing_key
# Build metadata stamped by the packaging CI step (ADR-099) — generated, not
# source. A plain checkout has none and falls back to the "source" revision.
mfl_desktop/_build_info.py

# Marketing screenshots (generated for the website handoff; not app source).
screenshots/

# Rotating DB snapshots + Data Library saves written by the app at runtime
# (ADR-057 / ADR-059). Local data, never source.
Snapshots/

# macOS noise
.DS_Store
